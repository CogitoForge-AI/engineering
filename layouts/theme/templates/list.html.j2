{% extends "base.html.j2" %}
{% block content %}
{% set items = page.get('items') %}
{% if items is not none %}
<section class="hero">
<div class="hero-brand">
<img class="hero-logo" src="{{ site.brand_logo }}" alt="Cogito AI">
</div>
<p class="hero-kicker">{{ site.organization }} engineering publication</p>
<h1>Writing from the teams building Cogito.</h1>
<p class="hero-body">{{ site.description }}</p>
<div class="hero-actions">
<a class="button button-primary" href="/write-for-us/">Start writing</a>
<a class="button button-secondary" href="/about/">About the publication</a>
</div>
<div class="hero-notes">
<div class="hero-note">
<p class="hero-note-label">What we publish</p>
<p>Architecture notes, AI evaluation lessons, reliability playbooks, and practical product engineering writeups.</p>
</div>
<div class="hero-note">
<p class="hero-note-label">Who it is for</p>
<p>Engineers inside Cogito, future teammates, and practitioners who want concrete stories from production systems.</p>
</div>
</div>
</section>
<section class="section-heading">
<p class="section-label">Latest posts</p>
<h2>What the team is learning in the open</h2>
</section>
<div class="post-list">
{% for post in items %}
<article class="post-summary">
<p class="eyebrow">Latest</p>
<h3><a href="{{ post.url }}">{{ post.title }}</a></h3>
<p class="post-meta">{% if post.date %}<time datetime="{{ post.date }}">{{ post.date }}</time>{% endif %}</p>
{% if post.excerpt %}<p class="excerpt">{{ post.excerpt }}</p>{% endif %}
{% if post.tags %}<p class="summary-tags">{% for tag in post.tags %}<span>#{{ tag }}</span> {% endfor %}</p>{% endif %}
</article>
{% endfor %}
</div>
{% set pg = page.get('pagination') %}
{% if pg and pg.total > 1 %}
<nav class="pagination">
{% if pg.prev %}<a class="prev" href="{{ pg.prev }}">&larr; {{ t("pagination.newer") }}</a>{% endif %}
<span class="page-indicator">{{ t("pagination.page_of", current=pg.current, total=pg.total) }}</span>
{% if pg.next %}<a class="next" href="{{ pg.next }}">{{ t("pagination.older") }} &rarr;</a>{% endif %}
</nav>
{% endif %}
<section class="home-grid">
<article class="info-card">
<p class="section-label">For contributors</p>
<h3>Turn project work into shared knowledge</h3>
<p>We want short, useful pieces that explain decisions, constraints, and what changed after the work shipped.</p>
<a href="/write-for-us/">Read the writing guide</a>
</article>
<article class="info-card">
<p class="section-label">Open source home</p>
<h3>Built in the open on GitHub</h3>
<p>The wider Cogito organization lives at `cogitoForge-AI`, and this publication is designed to be easy to edit with Markdown.</p>
<a href="{{ site.github_org_url }}" target="_blank" rel="noopener noreferrer">Visit the GitHub organization</a>
</article>
</section>
{% else %}
{# Standalone use (no collection): list pages grouped by section from the nav menu. #}
<h1>{{ page.title }}</h1>
<ul class="post-list">
{% for sec in menu %}{% if sec.section %}{% for item in sec['items'] %}
<li><a href="{{ item.url }}">{{ item.title }}</a></li>
{% endfor %}{% endif %}{% endfor %}
</ul>
{% endif %}
{% endblock %}
